{
  "manifest_version": 3,
  "name": "LineLens",
  "description": "Reader-first extension for focused long-form article reading.",
  "version": "0.0.0",
  "action": {
    "default_title": "LineLens"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["action", "storage", "tabs"],
  "host_permissions": ["https://x.com/*", "https://twitter.com/*"],
  "web_accessible_resources": [
    {
      "resources": ["reader.html"],
      "matches": ["https://x.com/*", "https://twitter.com/*"]
    }
  ]
}
